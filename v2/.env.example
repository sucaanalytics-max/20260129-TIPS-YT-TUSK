# =============================================================================
# Tusk YT × Stock — v2 environment
#
# Standalone deployment. Copy to .env.local for local dev. For Vercel production,
# set these in the Vercel dashboard or via `vercel env add`. Never commit .env*.
# =============================================================================

# ---- Supabase (NEW project recommended; old DB is bfafqccvzboyfjewzvhk) -----
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # server-only; never expose to client
SUPABASE_PUBLISHABLE_KEY=sb_pub_...         # only used if/when public reads are added

# ---- Auth (Clerk, native Vercel Marketplace integration) --------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Comma-separated email allowlist (Tusk-only). Enforced in middleware.
TUSK_ALLOWED_EMAIL_DOMAINS=tuskinvest.com

# ---- Cron auth (Vercel sends this Bearer to /api/cron/*) --------------------
CRON_SECRET=                                # generate: openssl rand -hex 32

# ---- YouTube Data API v3 ----------------------------------------------------
YOUTUBE_API_KEY=AIza...

# ---- Stock pricing (no key needed; Yahoo + NSE) -----------------------------
# Optional: override the symbols ingested (CSV)
STOCK_SYMBOLS=TIPSMUSIC,SAREGAMA

# ---- Market indices (Yahoo symbols) -----------------------------------------
# Drives market-model β for event-study CAR. CSV of name:yahoo_symbol pairs.
MARKET_INDEX_SYMBOLS=NIFTY_MIDCAP_150:^CRSMID,NIFTY_50:^NSEI

# ---- BSE scrip codes (for earnings ingest) ----------------------------------
# CSV of symbol:bse_code pairs. TIPSMUSIC=532375, SAREGAMA=532163.
BSE_SCRIP_CODES=TIPSMUSIC:532375,SAREGAMA:532163

# ---- Cache revalidation -----------------------------------------------------
# Public URL of the deployment. The Python stats service POSTs to
# `${NEXT_PUBLIC_APP_URL}/api/internal/revalidate` after writing new rows so
# `'use cache'` blocks refresh immediately. Leave blank locally.
NEXT_PUBLIC_APP_URL=

# ---- v1 → v2 backfill (only used by scripts/backfill-from-v1.ts) ------------
# v1 anon is fine — its RLS is USING(true). v1 project: bfafqccvzboyfjewzvhk
V1_SUPABASE_URL=
V1_SUPABASE_ANON_KEY=

# ---- Optional: Slack webhook for health-check alerts ------------------------
SLACK_ALERT_WEBHOOK_URL=
